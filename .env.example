# ============================================================
# 키움증권 REST API 인증 정보
# ============================================================
# 모의투자 / 실거래 각각 발급 (https://openapi.kiwoom.com)
KIWOOM_APP_KEY=your_app_key_here
KIWOOM_SECRET_KEY=your_secret_key_here
KIWOOM_MOCK=true                         # true=모의투자, false=실거래
# 키움은 계좌번호를 API body에 전달하지 않습니다 (토큰에 귀속)

# ============================================================
# 데이터베이스
# ============================================================
POSTGRES_USER=trading
POSTGRES_PASSWORD=trading1234
POSTGRES_DB=trading_db
DATABASE_URL=postgresql+asyncpg://trading:trading1234@postgres:5432/trading_db

# ============================================================
# Redis
# ============================================================
REDIS_PASSWORD=redis1234
REDIS_URL=redis://:redis1234@redis:6379/0

# ============================================================
# 매매 설정
# ============================================================
TOTAL_INVESTMENT=10000000    # 총 투자금 (원)

# ============================================================
# 서버
# ============================================================
SECRET_KEY=change_this_to_random_secret_key

# ============================================================
# 인증 (Phase 1)
# ============================================================
# JWT 서명 키 (32자 이상, 실 배포 시 반드시 랜덤 값으로 교체)
JWT_SECRET=change_this_to_random_jwt_secret_at_least_32_chars_long
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=720            # 12시간

# 최초 부팅 시 자동 생성되는 관리자 계정
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change_me_on_first_deploy
