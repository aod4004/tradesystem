# ============================================================
# 키움증권 REST API 인증 정보
# ============================================================
# 모의투자 / 실거래 각각 발급 (https://openapi.kiwoom.com)
KIWOOM_APP_KEY=your_app_key_here
KIWOOM_SECRET_KEY=your_secret_key_here
KIWOOM_MOCK=true                         # true=모의투자, false=실거래

# ============================================================
# 데이터베이스
# ============================================================
POSTGRES_USER=trading
POSTGRES_PASSWORD=trading1234
POSTGRES_DB=trading_db
DATABASE_URL=postgresql://trading:trading1234@postgres:5432/trading_db

# ============================================================
# Redis
# ============================================================
REDIS_PASSWORD=redis1234
REDIS_URL=redis://:redis1234@redis:6379/0

# ============================================================
# 매매 설정
# ============================================================
TOTAL_INVESTMENT=10000000    # 총 투자금 (원)

# ============================================================
# 서버
# ============================================================
SECRET_KEY=change_this_to_random_secret_key
